    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "groq-sdk": "^1.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "mongoose": "^9.6.3",
    "next": "16.2.6",
    "node-cron": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
